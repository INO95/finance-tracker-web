# Server Configuration
FINANCE_WEB_PORT=4380
FINANCE_WEB_HOST=127.0.0.1

# API Authentication (optional - leave empty to disable auth)
FINANCE_WEB_API_TOKEN=

# CORS Configuration (optional)
FINANCE_CORS_ORIGIN=*

# Storage Driver: sqlite (default) or json
FINANCE_STORAGE_DRIVER=sqlite

# SQLite file path (used when FINANCE_STORAGE_DRIVER=sqlite)
FINANCE_SQLITE_PATH=./data/finance_db.sqlite
